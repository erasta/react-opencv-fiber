{
  "name": "@react-opencv/fiber",
  "version": "0.1.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/erasta/react-opencv-fiber.git"
  },
  "description": "A React reconciler for building OpenCV.js image-processing pipelines declaratively",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "license": "MIT",
  "keywords": [
    "react",
    "opencv",
    "fiber",
    "reconciler",
    "image-processing",
    "computer-vision"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json && mkdir -p dist/data && cp src/data/opencv-signatures.json dist/data/",
    "prepack": "cp ../README.md ../LICENSE ."
  },
  "dependencies": {
    "react-reconciler": "^0.33.0"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
