{
  "name": "@react-opencv/fiber",
  "version": "0.1.4",
  "repository": {
    "type": "git",
    "url": "https://github.com/erasta/react-opencv-fiber.git"
  },
  "description": "A React reconciler for building OpenCV.js image-processing pipelines declaratively",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "license": "MIT",
  "keywords": [
    "react",
    "opencv",
    "fiber",
    "reconciler",
    "image-processing",
    "computer-vision"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json && mkdir -p dist/data && cp src/data/opencv-signatures.json dist/data/",
    "lint": "eslint .",
    "prepack": "npm run build",
    "postpublish": "git tag v$npm_package_version && git push origin v$npm_package_version"
  },
  "dependencies": {
    "react-reconciler": "^0.33.0"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-reconciler": "^0.33.0",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "playwright": "^1.58.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
